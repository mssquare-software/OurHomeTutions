import crypto from 'crypto';
import { DatabaseService } from './databaseService';
import Razorpay from 'razorpay';

// Check if Razorpay keys are valid
const isValidRazorpayKeys = () => {
  const keyId = process.env.RAZORPAY_KEY_ID;
  const keySecret = process.env.RAZORPAY_KEY_SECRET;
  return keyId && keyId && 
         keyId !== 'your_test_key_id_here' && 
         keySecret !== 'your_test_key_secret_here';
};

let razorpay: Razorpay | null = null;

// Initialize Razorpay only if keys are valid
if (isValidRazorpayKeys()) {
  razorpay = new Razorpay({
    key_id: process.env.RAZORPAY_KEY_ID!,
    key_secret: process.env.RAZORPAY_KEY_SECRET!,
  });
  console.log('✅ Razorpay initialized with valid keys');
} else {
  console.log('⚠️ Razorpay keys are placeholders, using mock payment mode');
}

export interface PaymentRequest {
  bookingId: string;
  amount: number;
  paymentMethod: 'razorpay' | 'paypal' | 'paytm' | 'bhim' | 'upi' | 'card' | 'scan_qr';
  customerInfo: {
    name: string;
    email: string;
    contact: string;
  };
}

export interface PaymentResponse {
  success: boolean;
  paymentId?: string;
  orderId?: string;
  transactionId?: string;
  paymentUrl?: string;
  qrCode?: string;
  upiId?: string;
  key?: string; // Razorpay key for frontend
  error?: string;
}

export class PaymentService {
  
  // Simple Razorpay Order Creation
  static async createOrder(amount: number) {
    const options = {
      amount: amount * 100, // IMPORTANT (₹ → paise)
      currency: "INR",
      receipt: "receipt_" + Date.now(),
    };

    const order: any = await razorpay.orders.create(options);
    return order;
  }

  // Simple Payment Verification
  static async verifyPayment(req: any, res: any) {
    const { razorpay_order_id, razorpay_payment_id, razorpay_signature } = req.body;

    const body = razorpay_order_id + "|" + razorpay_payment_id;

    const expectedSignature = crypto
      .createHmac("sha256", process.env.RAZORPAY_KEY_SECRET!)
      .update(body)
      .digest("hex");

    if (expectedSignature === razorpay_signature) {
      res.json({ success: true });
    } else {
      res.status(400).json({ success: false });
    }
  }

