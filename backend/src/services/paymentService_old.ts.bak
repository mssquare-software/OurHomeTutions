  // Scan QR Code Payment
  static async createScanQRPayment(paymentRequest: PaymentRequest): Promise<PaymentResponse> {
    try {
      const qrData = {
        upiId: process.env.BHIM_UPI_ID,
        merchantName: 'OurHomeTutions',
        amount: paymentRequest.amount,
        transactionNote: `Payment for booking ${paymentRequest.bookingId}`,
        transactionId: `QR_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`
      };

      // Generate QR code data (in production, use QR code library)
      const qrString = `upi://pay?pa=${qrData.upiId}&pn=${qrData.merchantName}&am=${qrData.amount}&cu=INR&tn=${qrData.transactionNote}&tr=${qrData.transactionId}`;

      return {
        success: true,
        transactionId: qrData.transactionId,
        qrCode: qrString, // In production, this would be actual QR code image
        upiId: qrData.upiId
      };

    } catch (error) {
      console.error('QR payment creation error:', error);
      return { success: false, error: 'Failed to create QR payment' };
    }
  }

  // Unified Payment Method Handler
  static async createPayment(paymentRequest: PaymentRequest): Promise<PaymentResponse> {
    switch (paymentRequest.paymentMethod) {
      case 'razorpay':
        return this.createRazorpayOrder(paymentRequest);
      case 'paypal':
        return this.createPayPalPayment(paymentRequest);
      case 'paytm':
        return this.createPaytmPayment(paymentRequest);
      case 'bhim':
      case 'upi':
        return this.createBhimUpiPayment(paymentRequest);
      case 'card':
        return this.createCardPayment(paymentRequest);
      case 'scan_qr':
        return this.createScanQRPayment(paymentRequest);
      default:
        return { success: false, error: 'Unsupported payment method' };
    }
  }

  // Verify Payment (Webhook Handler)
  static async verifyPayment(paymentMethod: string, paymentData: any): Promise<PaymentResponse> {
    try {
      switch (paymentMethod) {
        case 'razorpay':
          return this.verifyRazorpayPayment(paymentData);
        case 'paypal':
          return this.verifyPayPalPayment(paymentData);
        case 'paytm':
          return this.verifyPaytmPayment(paymentData);
        default:
          return { success: false, error: 'Payment verification not supported for this method' };
      }
    } catch (error) {
      console.error('Payment verification error:', error);
      return { success: false, error: 'Payment verification failed' };
    }
  }

  // Razorpay Payment Verification
  private static async verifyRazorpayPayment(paymentData: any): Promise<PaymentResponse> {
    try {
      const razorpaySecret = process.env.RAZORPAY_KEY_SECRET;
      const { razorpay_order_id, razorpay_payment_id, razorpay_signature } = paymentData;

      if (!razorpaySecret || !razorpay_order_id || !razorpay_payment_id || !razorpay_signature) {
        return { success: false, error: 'Invalid payment data' };
      }

      const generatedSignature = crypto
        .createHmac('sha256', razorpaySecret)
        .update(`${razorpay_order_id}|${razorpay_payment_id}`)
        .digest('hex');

      const isValid = generatedSignature === razorpay_signature;

      if (isValid) {
        // Optionally verify with Razorpay API
        try {
          const razorpayKey = process.env.RAZORPAY_KEY_ID;
          const auth = Buffer.from(`${razorpayKey}:${razorpaySecret}`).toString('base64');
          
          const response = await fetch(`https://api.razorpay.com/v1/payments/${razorpay_payment_id}`, {
            method: 'GET',
            headers: {
              'Authorization': `Basic ${auth}`,
              'Content-Type': 'application/json'
            }
          });

          if (response.ok) {
            const payment: any = await response.json();
            
            // Additional verification
            if (payment.order_id === razorpay_order_id && payment.status === 'captured') {
              return {
                success: true,
                transactionId: razorpay_payment_id
              };
            }
          }
        } catch (error) {
          console.error('Razorpay API verification failed:', error);
        }
      }

      return {
        success: isValid,
        transactionId: isValid ? razorpay_payment_id : undefined,
        error: isValid ? undefined : 'Invalid payment signature'
      };

    } catch (error) {
      console.error('Razorpay verification error:', error);
      return { success: false, error: 'Razorpay verification failed' };
    }
  }

