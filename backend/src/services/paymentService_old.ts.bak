  // Paytm Payment Verification
  private static async verifyPaytmPayment(paymentData: any): Promise<PaymentResponse> {
    try {
      // In production, verify with Paytm API
      const paytmMerchantKey = process.env.PAYTM_MERCHANT_KEY;
      
      if (!paytmMerchantKey) {
        return { success: false, error: 'Paytm credentials not configured' };
      }

      // Verify checksum
      const isValid = this.verifyPaytmChecksum(paymentData, paytmMerchantKey);

      return {
        success: isValid,
        transactionId: isValid ? paymentData.ORDERID : undefined,
        error: isValid ? undefined : 'Invalid Paytm checksum'
      };

    } catch (error) {
      console.error('Paytm verification error:', error);
      return { success: false, error: 'Paytm verification failed' };
    }
  }

  // Helper Methods
  private static generatePaytmChecksum(data: any, key: string): string {
    // In production, use Paytm's checksum library
    const sortedKeys = Object.keys(data).sort();
    const stringToHash = sortedKeys.map(key => `${key}=${data[key]}`).join('|');
    return crypto.createHash('sha256').update(stringToHash + key).digest('hex');
  }

  private static verifyPaytmChecksum(data: any, key: string): boolean {
    const receivedChecksum = data.CHECKSUMHASH;
    delete data.CHECKSUMHASH;
    const calculatedChecksum = this.generatePaytmChecksum(data, key);
    return receivedChecksum === calculatedChecksum;
  }

  // Update payment status in database
  static async updatePaymentStatus(paymentId: string, status: string, transactionId?: string): Promise<boolean> {
    try {
      const result = await DatabaseService.updatePaymentStatus(paymentId, status, transactionId);
      return result !== null;
    } catch (error) {
      console.error('Error updating payment status:', error);
      return false;
    }
  }
}
