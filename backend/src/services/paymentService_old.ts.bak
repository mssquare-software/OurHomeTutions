  // BHIM UPI Integration
  static async createBhimUpiPayment(paymentRequest: PaymentRequest): Promise<PaymentResponse> {
    try {
      const upiId = process.env.BHIM_UPI_ID;
      
      if (!upiId) {
        return { success: false, error: 'BHIM UPI ID not configured' };
      }

      const transactionId = `BHIM_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`;
      
      // Generate UPI payment URL
      const upiUrl = `upi://pay?pa=${upiId}&pn=OurHomeTutions&am=${paymentRequest.amount}&cu=INR&tn=Payment for booking ${paymentRequest.bookingId}&tr=${transactionId}`;

      return {
        success: true,
        transactionId,
        upiId,
        paymentUrl: upiUrl
      };

    } catch (error) {
      console.error('BHIM UPI payment creation error:', error);
      return { success: false, error: 'Failed to create BHIM UPI payment' };
    }
  }

