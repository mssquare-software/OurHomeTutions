# Payment Gateway Configuration

# Razorpay Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# PayPal Configuration
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
PAYPAL_MODE=sandbox # sandbox or live

# Paytm Configuration
PAYTM_MERCHANT_ID=your_paytm_merchant_id_here
PAYTM_MERCHANT_KEY=your_paytm_merchant_key_here
PAYTM_WEBSITE=your_paytm_website_here
PAYTM_CHANNEL_ID=WEB
PAYTM_INDUSTRY_TYPE_ID=Retail

# BHIM UPI Configuration
BHIM_UPI_ID=your_upi_id@bank

# Stripe Configuration (for Card Payments)
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# Frontend URL (for redirects)
FRONTEND_URL=http://localhost:3000

# Webhook URLs (configure in payment gateways)
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id_here
PAYTM_WEBHOOK_URL=https://yourdomain.com/api/payments/paytm/webhook
